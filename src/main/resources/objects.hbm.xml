<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
    <class name="com.otzar.sscm.model.SocialManagerEntity" table="social_managers">
        <id name="id" column="id" type="long">
            <generator class="identity"/>
        </id>
        <property name="fullName" column="full_name" type="string" not-null="true"/>
        <property name="username" column="username" type="string" not-null="true"/>
        <property name="email" column="email" type="string" not-null="true"/>
    </class>

    <class name="com.otzar.sscm.model.ClientEntity" table="clients">
        <id name="id" column="id" type="long">
            <generator class="identity"/>
        </id>
        <many-to-one
                name="socialManagerEntity"
                column="social_manager_id"
                class="com.otzar.sscm.model.SocialManagerEntity" />
        <property name="businessName" column="business_name" type="string" not-null="true"/>
        <property name="phone" column="phone" type="string"/>
    </class>

</hibernate-mapping>
